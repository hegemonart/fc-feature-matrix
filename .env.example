# Neon Postgres — pooled connection (runtime queries, ends in -pooler)
DATABASE_URL=

# Neon Postgres — direct connection (migrations only, no -pooler suffix)
DATABASE_URL_UNPOOLED=

# HMAC-SHA256 session signing secret (min 32 chars, required in prod)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Resend API key for transactional email (access request notifications)
RESEND_API_KEY=

# Bearer token for the Vercel Cron retention endpoint (required in prod)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
